{
  "name": "angular-template",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "refresh-swagger": ".\\refresh.bat",
    "deploy:production": "node --max-old-space-size=8192 ./node_modules/@angular/cli/bin/ng build --configuration=production --build-optimizer --base-href /",
    "deploy:test": "node --max-old-space-size=8192 ./node_modules/@angular/cli/bin/ng build --configuration=test --build-optimizer --base-href /Connect/",
    "nswag:generate": "node tools/generate-nswag.js",
    "generate:backend-index": "node tools/generate-backendservices-index.js",
    "generate:dto-shapes": "node tools/generate-dto-shapes.js",
    "save-config-server": "node tools/save-config-server.js",
    "save-nswag-server": "node tools/save-nswag-server.js",
    "check:text-encoding": "node tools/check-text-encoding.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^15.2.0",
    "@angular/cdk": "^15.2.0",
    "@angular/common": "^15.2.0",
    "@angular/compiler": "^15.2.0",
    "@angular/core": "^15.2.0",
    "@angular/forms": "^15.2.10",
    "@angular/platform-browser": "^15.2.0",
    "@angular/platform-browser-dynamic": "^15.2.0",
    "@angular/router": "^15.2.0",
    "@auth0/angular-jwt": "^5.2.0",
    "@microsoft/signalr": "^7.0.12",
    "@ngx-formly/bootstrap": "^6.3.5",
    "@ngx-formly/core": "^6.3.5",
    "bootstrap": "^5.3.3",
    "chart.js": "^4.4.3",
    "chartjs-plugin-datalabels": "^2.2.0",
    "driver.js": "^1.4.0",
    "file-saver": "^2.0.5",
    "jquery": "^3.7.1",
    "ngx-barcode": "^0.3.0",
    "ngx-print": "^1.3.1",
    "ngx-spinner": "^8.1.0",
    "nswag": "^13.20.0",
    "primeicons": "^7.0.0",
    "primeng": "^15.4.1",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.11.1",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5",
    "zone.js": "~0.12.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^15.2.11",
    "@angular/cli": "~15.2.11",
    "@angular/compiler-cli": "^15.2.0",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "~4.3.0",
    "jasmine-core": "~4.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "typescript": "~4.9.4"
  }
}
